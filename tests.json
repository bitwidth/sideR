      { "status": "OK", "data": ["1", "2", "3", "4"] }
    ]
  },
  {
    "name": "Range fetch from negative start and end",
    "commands": ["LRANGE arrRange -2 -1;"],
    "results": [{ "status": "OK", "data": ["4", "5"] }]
  },
  {
    "name": "Range fetch from positive start and negative end",
    "commands": ["LRANGE arrRange 0 -1;"],
